# Copy to `.env` for local development. Never commit `.env`.

# Database
DATABASE_URL=
# Optional: if your host provides a Prisma-specific variable name (e.g. some Vercel setups)
DATABASE_PRISMA_DATABASE_URL=

# Auth
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Admin bootstrap (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Cloudflare R2 (uploads)
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
# Optional
R2_ENDPOINT=
R2_DISCUSSIONS_PREFIX=
R2_ANNOUNCEMENTS_PREFIX=

# Cron endpoints (required in production)
CRON_SECRET=

# Rate limiting (optional, recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

