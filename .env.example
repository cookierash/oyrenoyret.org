# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Node Environment
NODE_ENV=development

# Database
# PostgreSQL connection string
# For Vercel Postgres: Get from Vercel Dashboard → Storage → Your Database → .env.local tab
# Format: postgresql://user:password@host:port/database?schema=public
# Vercel Postgres provides POSTGRES_URL - use that as DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/oyrenoyret?schema=public"

# NextAuth.js Configuration
# Generate a secure random string (minimum 32 characters)
# You can use: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"

# Application URL
# In production, set this to your actual domain
# For Vercel: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Cron Jobs (required in production)
# For /api/cron/archive-discussions - set a secret and pass as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -base64 24
CRON_SECRET=

# Security Notes:
# - All secrets should be at least 32 characters long (16 for CRON_SECRET)
# - Use different secrets for development and production
# - Never expose these values to the client
# - Rotate secrets regularly in production
# - Vercel automatically injects POSTGRES_URL in production