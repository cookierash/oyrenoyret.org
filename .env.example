# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Node Environment
NODE_ENV=development

# Database
# PostgreSQL connection string
# For Vercel Postgres: Get from Vercel Dashboard → Storage → Your Database → .env.local tab
# Format: postgresql://user:password@host:port/database?schema=public
# Vercel Postgres provides POSTGRES_URL - use that as DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/oyrenoyret?schema=public"

# NextAuth.js Configuration
# Generate a secure random string (minimum 32 characters)
# You can use: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"

# Application URL
# In production, set this to your actual domain
# For Vercel: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
# Create API key at https://resend.com
# EMAIL_FROM must be a verified sender/domain in Resend
RESEND_API_KEY=
EMAIL_FROM="oyrenoyret <no-reply@oyrenoyret.org>"

# Cron Jobs (required in production)
# For /api/cron/archive-discussions - set a secret and pass as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -base64 24
CRON_SECRET=
# Optional: Hours of inactivity before archive/removal (default 24)
DISCUSSION_INACTIVITY_HOURS=24

# Optional: Session cache TTL in milliseconds (default 60000)
SESSION_CACHE_TTL_MS=60000

# Optional: Use mocked Google Fonts responses for offline builds.
# Must be an absolute path (Node resolves relative to Next internals).
# Example: /absolute/path/to/oyrenoyret.org/scripts/next-font-mocks.cjs
NEXT_FONT_GOOGLE_MOCKED_RESPONSES=

# Security Notes:
# - All secrets should be at least 32 characters long (16 for CRON_SECRET)
# - Use different secrets for development and production
# - Never expose these values to the client
# - Rotate secrets regularly in production
# - Vercel automatically injects POSTGRES_URL in production
